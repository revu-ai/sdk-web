{
  "name": "@revu-ai/core",
  "version": "0.1.0",
  "description": "REVU Web SDK - lean capture core (autocapture, identity, queue, transport). Vanilla JS + JSDoc.",
  "author": "Tarek Raafat",
  "license": "Apache-2.0",
  "homepage": "https://github.com/revu-ai/sdk-web/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/revu-ai/sdk-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revu-ai/sdk-web.git",
    "directory": "packages/core"
  },
  "keywords": [
    "analytics",
    "behavioral-analytics",
    "autocapture",
    "web-analytics",
    "sdk",
    "tracking",
    "browser",
    "events",
    "revu"
  ],
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "unpkg": "./dist/iife/index.js",
  "jsdelivr": "./dist/iife/index.js",
  "files": ["dist", "src"],
  "scripts": {
    "sync-version": "bun scripts/sync-version.js",
    "prebuild": "bun scripts/sync-version.js",
    "build": "bun scripts/build.js",
    "types": "tsc -p tsconfig.json --outDir dist",
    "size": "size-limit"
  },
  "size-limit": [
    { "name": "core (esm, raw min)",  "path": "dist/index.js",           "limit": "30 kB", "gzip": false, "brotli": false, "disablePlugins": ["@size-limit/esbuild"] },
    { "name": "core (esm, raw gzip)", "path": "dist/index.js",           "limit": "10 kB", "gzip": true,                   "disablePlugins": ["@size-limit/esbuild"] },
    { "name": "core (iife, raw min)", "path": "dist/iife/index.js",      "limit": "32 kB", "gzip": false, "brotli": false, "disablePlugins": ["@size-limit/esbuild"] },
    { "name": "core (iife, raw gzip)","path": "dist/iife/index.js",      "limit": "11 kB", "gzip": true,                   "disablePlugins": ["@size-limit/esbuild"] }
  ]
}
