{
  "name": "@revu-ai/core",
  "version": "0.1.0",
  "description": "REVU Web SDK - lean capture core (autocapture, identity, queue, transport). Vanilla JS + JSDoc.",
  "author": "Tarek Raafat",
  "license": "Apache-2.0",
  "homepage": "https://github.com/revu-ai/sdk-web/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/revu-ai/sdk-web/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revu-ai/sdk-web.git",
    "directory": "packages/core"
  },
  "keywords": [
    "analytics",
    "behavioral-analytics",
    "autocapture",
    "web-analytics",
    "sdk",
    "tracking",
    "browser",
    "events",
    "revu"
  ],
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "bun build ./src/index.js --outdir ./dist --format esm --target browser --sourcemap=linked",
    "types": "tsc -p tsconfig.json --outDir dist",
    "size": "size-limit"
  },
  "size-limit": [
    { "name": "core (esm, min)", "path": "dist/index.js", "limit": "30 kB", "gzip": false, "brotli": false },
    { "name": "core (esm, gzip)", "path": "dist/index.js", "limit": "10 kB", "gzip": true }
  ]
}
