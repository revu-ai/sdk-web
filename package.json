{
  "name": "revu-sdk-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "REVU Web SDK monorepo - one-line autocapture + opt-in modules. Vanilla JS + JSDoc; types generated at build.",
  "author": "Tarek Raafat",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revu-ai/sdk-web.git"
  },
  "workspaces": ["packages/*"],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "types": "bun run --filter '*' types",
    "test": "bun test",
    "lint": "eslint \"packages/**/src/**/*.js\" \"packages/**/test/**/*.js\"",
    "format": "prettier --write \"packages/**/src/**/*.js\" \"packages/**/test/**/*.js\"",
    "size": "bun run --filter '*' size"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.2",
    "@size-limit/preset-small-lib": "^12.1.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "size-limit": "^12.1.0",
    "typescript": "^6.0.3"
  }
}
